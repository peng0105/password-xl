def BRANCH = 'master'
def PROJECT = 'password-xl'
def MODULE = 'password-xl-web'

pipeline {
    agent {
        label 'nodejs-24'
    }

    triggers {
        GenericTrigger(
            genericVariables: [
                [key: 'ref', value: '$.ref'],
                [key: 'files', value: '$.commits[*].modified[*]'],
                [key: 'files_added', value: '$.commits[*].added[*]'],
                [key: 'files_removed', value: '$.commits[*].removed[*]']
            ],
            causeString: 'Gitea 推送触发构建: $ref',
            token: "${PROJECT}",
            regexpFilterText: '$ref $files $files_added $files_removed',
            regexpFilterExpression: "(?s)^refs/heads/${BRANCH}.*(${MODULE}/|k8s/web/).*"
        )
    }

    environment {
        IMAGE_NAME = "repo.huangyp.cn/${PROJECT}/${MODULE}"
        YARN_REGISTRY = "https://nexus.huangyp.cn/repository/npm-group/"
        MODULE_NAME = "${MODULE}"
        PROJECT_NAME = "${PROJECT}"
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timeout(time: 10, unit: 'MINUTES')
    }

    stages {
        stage('Install & Build') {
            steps {
                container('node') {
                    sh '''#!/bin/bash

set -euo pipefail

echo "🏗️ 设置npm仓库..."
yarn config set registry ${YARN_REGISTRY}

cd ${MODULE_NAME}

echo "📦 安装依赖..."
yarn install

echo "🛠️ 构建前端静态资源..."
yarn build

                    '''
                }
            }
        }

        stage('Build & Push Image') {
          steps {
            container('buildkit') {
              sh '''

set -euo pipefail

echo "🛠️ 使用 BuildKit 构建并推送镜像..."
buildctl-daemonless.sh build \
--frontend dockerfile.v0 \
--local context="${WORKSPACE}/${MODULE_NAME}" \
--local dockerfile="${WORKSPACE}/${MODULE_NAME}" \
--opt filename=Dockerfile \
--output type=image,\\"name=${IMAGE_NAME}:${BUILD_NUMBER},${IMAGE_NAME}:latest\\",push=true

              '''
            }
          }
        }

        stage('Deploy to Kubernetes') {
            steps {
                container('kubectl') {
                    sh '''#!/bin/bash

set -euo pipefail

echo "🚀 部署 Web 相关 K8s 配置..."
kubectl apply -f k8s/web/service.yaml
kubectl apply -f k8s/web/deployment.yaml
kubectl apply -f k8s/web/ingress.yaml

echo "🔄 更新 Deployment 镜像..."
kubectl set image deployment/${MODULE_NAME} \
${MODULE_NAME}=${IMAGE_NAME}:${BUILD_NUMBER} \
-n ${PROJECT_NAME}

echo "⏳ 等待滚动更新完成..."
kubectl rollout status deployment/${MODULE_NAME} -n ${PROJECT_NAME} --timeout=60s

echo "✅ 部署完成"

                    '''
                }
            }
        }
    }
}
